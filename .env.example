# Munnir — environment variables
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# News ingestion (https://newsapi.org/register — free tier: 100 req/day)
NEWSAPI_KEY=your-newsapi-key-here

# AI analysis (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: enable background news scheduler (default: false)
NEWS_SCHEDULER_ENABLED=false
